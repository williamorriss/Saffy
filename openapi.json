{
  "openapi": "3.1.0",
  "info": {
    "title": "knowle",
    "description": "knowle dev api",
    "contact": {
      "name": "will",
      "email": "wvam20@bath.ac.uk"
    },
    "license": {
      "name": ""
    },
    "version": "-10.0.0"
  },
  "paths": {
    "/api/issues": {
      "get": {
        "tags": [
          "crate::issues"
        ],
        "operationId": "get_issues",
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "showOpen",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "showClosed",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "location",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "dateAfter",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "dateBefore",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "ordering",
            "in": "query",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/IssueQueryOrder"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "All issues",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Issue"
                  }
                }
              }
            }
          },
          "500": {
            "description": "Could not make new issue"
          }
        }
      },
      "post": {
        "tags": [
          "crate::issues"
        ],
        "operationId": "post_issue",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateIssue"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "New issue created"
          },
          "500": {
            "description": "Failed to create new issue"
          }
        }
      }
    },
    "/auth/cas/{auth_id}": {
      "get": {
        "tags": [
          "crate::auth"
        ],
        "operationId": "cas_callback",
        "parameters": [
          {
            "name": "auth_id",
            "in": "path",
            "description": "Issued ID upon entering the login endpoint",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "301": {
            "description": "Redirect to redirect url"
          },
          "400": {
            "description": "Malformed URL redirect"
          },
          "404": {
            "description": "Auth ID not recognised"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/auth/login": {
      "get": {
        "tags": [
          "crate::auth"
        ],
        "operationId": "login",
        "parameters": [
          {
            "name": "redirect",
            "in": "query",
            "description": "Url to redirect to after login",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "303": {
            "description": "Redirect to CAS auth"
          },
          "400": {
            "description": "Malformed URL redirect"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "tags": [
          "crate::auth"
        ],
        "operationId": "logout",
        "responses": {
          "303": {
            "description": "Redirect to CAS logout"
          }
        }
      }
    },
    "/auth/session": {
      "get": {
        "tags": [
          "crate::auth"
        ],
        "operationId": "get_session",
        "responses": {
          "200": {
            "description": "User",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "404": {
            "description": "User not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateIssue": {
        "type": "object",
        "required": [
          "locationUuid"
        ],
        "properties": {
          "title": {
            "type": [
              "string",
              "null"
            ]
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "locationUuid": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "CreateReport": {
        "type": "object",
        "required": [
          "issueId",
          "description"
        ],
        "properties": {
          "issueId": {
            "type": "string",
            "format": "uuid"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "Issue": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": [
              "string",
              "null"
            ]
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "IssueQueryOrder": {
        "type": "string",
        "enum": [
          "OldestFirst",
          "NewestFirst",
          "Relevance",
          "RecentlyUpdated"
        ]
      },
      "Location": {
        "type": "object",
        "required": [
          "id",
          "latitude",
          "longitude",
          "level"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "latitude": {
            "type": "number",
            "format": "float"
          },
          "longitude": {
            "type": "number",
            "format": "float"
          },
          "level": {
            "type": "integer",
            "format": "int32"
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "Report": {
        "type": "object",
        "required": [
          "id",
          "issueId",
          "reporter",
          "createdAt"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "issueId": {
            "type": "string",
            "format": "uuid"
          },
          "reporter": {
            "type": "string",
            "format": "uuid"
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "closedAt": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        }
      },
      "User": {
        "type": "object",
        "required": [
          "id",
          "username",
          "createdAt"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "username": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}