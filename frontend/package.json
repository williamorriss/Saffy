{
  "name": "knowle",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "gen-types": "npx openapi-typescript ../openapi.json -o ./src/types/api.d.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx,mjs,js,jsx,mdx --report-unused-disable-directives",
    "lint:fix": "eslint src --ext ts,tsx,mjs,js,jsx --report-unused-disable-directives --fix",
    "format": "prettier --write 'src/**/*.tsx' 'src/**/*.ts' '**/*.json' .prettierrc .eslintrc"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/vite": "^4.2.1",
    "eslint-plugin-prettier": "^5.5.5",
    "fast-xml-parser": "^5.3.4",
    "jose": "^6.1.3",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^6.7.6",
    "package": "^1.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^10.0.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "json-schema-to-typescript": "^15.0.4",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.36.0",
    "vite": "^7.3.1"
  }
}
