{
  "name": "knowle",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "openapi-typescript http://localhost:8000/openapi.json -o src/api/types.ts",
    "dev": "concurrently \"vite\" \"npm run watch-types\"",
    "fetch-spec": "curl http://localhost:8000/openapi.json -o openapi.json",
    "watch-types": "chokidar 'openapi.json' -c 'openapi-typescript openapi.json -o src/api/types.ts'",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx,mjs,js,jsx,mdx --report-unused-disable-directives",
    "lint:fix": "eslint src --ext ts,tsx,mjs,js,jsx --report-unused-disable-directives --fix",
    "format": "prettier --write 'src/**/*.tsx' 'src/**/*.ts' '**/*.json' .prettierrc .eslintrc"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@hookform/resolvers": "^5.2.2",
    "fast-xml-parser": "^5.3.4",
    "fuse.js": "^7.3.0",
    "jose": "^6.1.3",
    "lucide-react": "^1.8.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/react-slider": "^1.3.6",
    "@vitejs/plugin-react": "^5.1.1",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^8.0.0",
    "globals": "^16.5.0",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.36.0",
    "vite": "^7.3.1"
  }
}